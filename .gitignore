# ===========================================================================
# OS / editor cruft
# ===========================================================================
.DS_Store
*.swp
*.swo
*~
.idea/
.vscode/

# ===========================================================================
# Python build artifacts
# ===========================================================================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.ipynb_checkpoints/

# ===========================================================================
# Julia build artifacts
# ===========================================================================
julia/.julia/
julia/*.jl.cov
julia/*.jl.*.cov
julia/*.jl.mem

# ===========================================================================
# R build artifacts
# ===========================================================================
.Rhistory
.RData
.Rproj.user/

# ===========================================================================
# Large external data (download via scripts/download_data.sh from Zenodo
# or original sources documented in data/README.md)
# ===========================================================================
data/RFF-SP-emissions/
data/RFF-SP-socioeconomics/
# MimiBRICK release artifacts are large (~1 GB) — fetch from MimiBRICK
# release page on first run; only the posterior subsample CSV is needed
# and stays small. Keep that one explicitly tracked below.
data/MimiBRICK/*
!data/MimiBRICK/README.md
!data/MimiBRICK/.gitkeep

# ===========================================================================
# Large intermediate cubes — regenerable from FaIR (Tier 3) or Zenodo
# ===========================================================================
outputs/*.npz
outputs/lhs_pilot_*chunk*
outputs/lhs_pilot_*test*
outputs/lhs_pilot_*replay*

# ===========================================================================
# Large weighted ensembles — fetch from Zenodo, regenerable via BRICK pipeline
# ===========================================================================
outputs/brick_lhs10k_*.csv
outputs/brick_anova_long_2300.csv
outputs/brick_anova_long_2300.csv.prefix-backup
outputs/brick_anova_long_2300_weighted.csv
outputs/brick_anova_long_2300_weighted.csv.prefix-backup
outputs/brick_anova_pulse_long_2300.csv
outputs/brick_anova_pulse_long_2300.csv.prefix-backup
outputs/brick_anova_marginal_long_2300_weighted.csv
outputs/brick_anova_long.csv
outputs/brick_anova_pulse_long.csv
outputs/brick_lB_per_post_dangendorf.csv
outputs/brick_lB_per_post_csiro.csv

# Legacy 500-cell paired ensembles (superseded by LHS-10k for headline
# figures, but pulse_convergence.py consumes the small-pulse CO2/CH4
# variants AND the baseline — all 7 paired CSVs are tracked, ~30 MB total).

# ===========================================================================
# Diagnostic / R&D outputs
# ===========================================================================
outputs/bootstrap_convergence_*.csv
outputs/brick_ofat_long.csv
outputs/cross_*.csv
outputs/cross_*.log
outputs/chunk*.log
outputs/ssp245_validation_cube.npz
outputs/figure4_gmst*.csv
outputs/figure4_gmst*.png
outputs/figure4_gmst*.pdf
outputs/halfdeg_exceedance*.csv
outputs/lhs_pilot_gmst_traj*.csv
outputs/lhs_pilot_metadata*.csv
outputs/exceedance_*_data.csv

# Single-RFF debug outputs
outputs/rff_draw1_*.csv

# FrEDI integration workstream outputs (separate from SLR figures)
outputs/fredi_input_*.csv
outputs/fredi_*.csv

# ===========================================================================
# Output PDFs and per-panel intermediate PNGs we don't want versioned
# (final figure PNGs/PDFs ARE versioned via explicit git add)
# ===========================================================================
outputs/plots/*.pdf
outputs/poster/_review_*
outputs/poster/_tipping_*
outputs/poster/*.csv

# ===========================================================================
# Slurm job logs + stoch-test logs
# ===========================================================================
slurm/logs/
*.out
*.err
outputs/stoch_test*.log

# FrEDI smoketest outputs
outputs/smoketest_fredi_*.csv

# Layout-mockup PDF/PNG are regenerated by layout_mockup.py; keep only PNG
# (smaller, sufficient for review). The PDF is large because of embedded
# panel images.
outputs/poster/layout_mockup.pdf

# ===========================================================================
# Other
# ===========================================================================
.archive/
*.backup
*.bak
