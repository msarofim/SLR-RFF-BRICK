# ===========================================================================
# OS / editor cruft
# ===========================================================================
.DS_Store
*.swp
*.swo
*~
.idea/
.vscode/

# ===========================================================================
# Python build artifacts
# ===========================================================================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.ipynb_checkpoints/

# ===========================================================================
# Julia build artifacts
# ===========================================================================
julia/.julia/
julia/*.jl.cov
julia/*.jl.*.cov
julia/*.jl.mem

# ===========================================================================
# R build artifacts
# ===========================================================================
.Rhistory
.RData
.Rproj.user/

# ===========================================================================
# Large external data (download via scripts/download_data.sh from Zenodo
# or original sources documented in data/README.md)
# ===========================================================================
data/RFF-SP-emissions/
data/RFF-SP-socioeconomics/
# MimiBRICK release artifacts are large (~1 GB) — fetch from MimiBRICK
# release page on first run; only the posterior subsample CSV is needed
# and stays small. Keep that one explicitly tracked below.
data/MimiBRICK/*
!data/MimiBRICK/README.md
!data/MimiBRICK/.gitkeep

# ===========================================================================
# Large intermediate cubes — regenerable from FaIR (Tier 3) or Zenodo
# ===========================================================================
outputs/*.npz
outputs/lhs_pilot_*chunk*
outputs/lhs_pilot_*test*
outputs/lhs_pilot_*replay*

# ===========================================================================
# Large weighted ensembles — fetch from Zenodo, regenerable via BRICK pipeline
# ===========================================================================
outputs/brick_lhs10k_*.csv
outputs/brick_anova_long_2300.csv
outputs/brick_anova_long_2300.csv.prefix-backup
outputs/brick_anova_long_2300_weighted.csv
outputs/brick_anova_long_2300_weighted.csv.prefix-backup
outputs/brick_anova_pulse_long_2300.csv
outputs/brick_anova_pulse_long_2300.csv.prefix-backup
outputs/brick_anova_marginal_long_2300_weighted.csv
outputs/brick_anova_long.csv
outputs/brick_anova_pulse_long.csv
outputs/brick_lB_per_post_dangendorf.csv
outputs/brick_lB_per_post_csiro.csv

# Legacy 500-cell paired ensembles (superseded by LHS-10k for headline
# figures, but pulse_convergence.py consumes the small-pulse CO2/CH4
# variants AND the baseline — all 7 paired CSVs are tracked, ~30 MB total).

# ===========================================================================
# Diagnostic / R&D outputs
# ===========================================================================
outputs/bootstrap_convergence_*.csv
outputs/brick_ofat_long.csv
outputs/cross_*.csv
outputs/cross_*.log
outputs/chunk*.log
outputs/ssp245_validation_cube.npz
outputs/figure4_gmst*.csv
outputs/figure4_gmst*.png
outputs/figure4_gmst*.pdf
outputs/halfdeg_exceedance*.csv
outputs/lhs_pilot_gmst_traj*.csv
outputs/lhs_pilot_metadata*.csv
outputs/exceedance_*_data.csv

# Single-RFF debug outputs
outputs/rff_draw1_*.csv

# FrEDI integration workstream outputs (separate from SLR figures)
outputs/fredi_input_*.csv
outputs/fredi_*.csv

# ===========================================================================
# Output PDFs and per-panel intermediate PNGs we don't want versioned
# (final figure PNGs/PDFs ARE versioned via explicit git add)
# ===========================================================================
outputs/plots/*.pdf
outputs/poster/_review_*
outputs/poster/_tipping_*
outputs/poster/*.csv

# ===========================================================================
# Slurm + local job logs
# ===========================================================================
slurm/logs/
logs/
*.out
*.err
*.log

# FrEDI smoketest outputs
outputs/smoketest_fredi_*.csv

# Layout-mockup PDF/PNG are regenerated by layout_mockup.py; keep only PNG
# (smaller, sufficient for review). The PDF is large because of embedded
# panel images.
outputs/poster/layout_mockup.pdf

# ===========================================================================
# Other
# ===========================================================================
.archive/
*.backup
*.bak

# IEc handoff zip is re-buildable from the unpacked folder.
outputs/poster/iec_graphics_handoff.zip

# ===========================================================================
# v1.4.5 BRICK pipeline outputs (large; data on /scratch, summaries in CSV)
# ===========================================================================
# Slim per-arm weighted CSVs are 81 MB (LHS) to 435 MB (ANOVA) each — too big
# for git. Keep on disk for downstream plot scripts; pull from Torch when
# needed via rsync.
outputs/brick_v145_slim/*.csv

# Full Wong-pipeline weighted CSVs (460 MB LHS + 956 MB ANOVA each) likewise
# stay on /scratch + local disk only. The small per-arm envelopes (~500 KB)
# are kept in git for figure reproducibility.
outputs/brick_v145_summaries/*_weighted.csv

# Full per-cell BRICK driver outputs (~485 MB each) — these are the raw
# per-cell, per-component trajectories used by the brick_vs_grinsted TSLS
# component-decomposition figure and any per-cell L-T classification.
# Stay on Torch + local disk only; not committed.
outputs/brick_v145/*.csv

# Quarantined pre-fix outputs are large; the per-directory README is tracked
# but the CSVs themselves stay on local disk for postmortem only.
outputs/quarantine/**/*.csv
outputs/quarantine/**/*.npz

# Smoke / scratch outputs from the flatcube driver
outputs/flatcube_smoke_*.csv

# Obs-driven BRICK runs (large; reproducible via julia/run_mimibrick_obs_driven.jl)
outputs/brick_obsdriven_*.csv
parameters_subsample_sneasybrick.csv

# Diagnostic cross-posterior / sample-stability test outputs (large CSVs)
outputs/brick_xtest_prepr93/*.csv
outputs/brick_anova_stab_*.csv

# ===========================================================================
# v5 / Group-Sobol workstream large outputs (regenerable; data on Zenodo +
# Torch /scratch). The small per-axis decomposition CSVs and all figures ARE
# tracked; only the multi-GB raw ensembles and multi-MB regenerable metadata
# are excluded.
# ===========================================================================
# Raw per-cell BRICK trajectories for the LHS-10k_s noise-isolated ensemble
# (~2.4 GB). Regenerable via the BRICK arm; summaries/figures are tracked.
outputs/brick_v145_lhs10ks/
# Large regenerable ANOVA/feature metadata (rebuild via
# build_anova_factorial_metadata.py / build_rff_features_rich.py with fixed
# seeds). Small design metadata (<1 MB) stays tracked for reproducibility.
outputs/anova324k_brick_metadata.csv
outputs/anova324k_fair_metadata.csv
outputs/anova108k_brick_metadata.csv
outputs/lhs10ks_brick_postaugment_metadata.csv
outputs/rff_features_rich.csv
